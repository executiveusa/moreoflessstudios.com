# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=moreofless-media
R2_PUBLIC_URL=                          # Optional: custom domain for R2 public access

# ── Anthropic (Pi agent chat) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs (voice STT/TTS) ───────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── ACE-Step worker ──────────────────────────────────────────────────────────
ACESTEP_API_URL=https://your-worker.railway.app   # Deployed ACE-Step FastAPI
WORKER_API_KEY=your-worker-secret                  # Shared secret for job dispatch

# ── fal.ai (video + image generation) ────────────────────────────────────────
FALAI_API_KEY=

# ── Stripe (billing) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
